  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "                                                                        
    Mohey JSON System Instructions\n\nThis system allows you to manage multiple JSON
    files simultaneously using Unity's ScriptableObject.\n\nHow to Use\n\n1- Create
    a new ScriptableObject to store the data you want to save as JSON (Refer to the
    example in  the ExampleScene/JSONReaders.\n\n2- Define the variables to be serialized
    and saved as JSON.\n\n3- Update the menuName in the [CreateAssetMenu] attribute
    to ensure you can create instances via the Unity Editor.\n\n4- Add the JSONReader
    component to your scene, referencing your ScriptableObject through the Inspector.\n\n5-
    Configure Action on Awake:\nSelect whether the JSONReader should Save, Load,
    or do Nothing on Awake.\nUse \"Save\" to create the JSON file initially, then
    switch to Load to pull data from the file.\n\n6- Manual Save/Load:\nYou can manually
    control saving and loading using the SaveData() and LoadData() methods.\n\n7-
    Modify the jsonFilepath in JSONReader if you need to change where JSON files
    are stored.\n\nNote: The JSON file is named based on the ScriptableObject name,
    so ensure it\u2019s descriptive."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
